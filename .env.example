# Strike Generation Configuration
STRIKE_BUFFER_POINTS=50

# Dynamic wing width by VIX regime (pts from short to long strike)
# VIX < 13 (calm): narrower wing = less capital at risk
WING_WIDTH_LOW_VIX=150
# VIX 13-20 (normal): standard wing
WING_WIDTH_MID_VIX=200
# VIX ≥ 20 (high): wider wing = capture more premium at higher vol
WING_WIDTH_HIGH_VIX=250

# VIX Baseline for dynamic buffer scaling (optional)
# If not set, computed automatically from 52-week India VIX historical mean
# VIX_BASELINE=16.0

# Put skew: extra OTM points for put strike (default: 0 for no skew)
# Calibrate from backtest; typical range 0-150 pts depending on market regime
PUT_SKEW_POINTS=0

# Call skew: extra OTM points for call strike (default: 0 for no skew)
# Use to address asymmetric breach rates (e.g., if call breach > put breach)
CALL_SKEW_POINTS=50

# Minimum buffer floor in low-VIX regimes (default: 75 pts)
# Prevents buffer from shrinking below this level when VIX scalar < 1
MIN_BUFFER_POINTS=75

# Base premium for backtest (dynamically scaled by VIX per-row)
PREMIUM_POINTS_BASE=80

# Conformal calibration target coverage
TARGET_COVERAGE=0.90

# ─────────────────────────────────────────────────────────────────────────────
# Credit Spread Configuration (module9_spreads.py)
# ─────────────────────────────────────────────────────────────────────────────

# Minimum reward:risk ratio for a spread to be considered acceptable
# Example: 0.15 means "collect at least 15% of max loss as premium"
MIN_RR_RATIO=0.15

# Annualized risk-free rate for Black-Scholes option pricing
# (India 91-day T-bill yield, ~6.5%)
RISK_FREE_RATE=0.065

# Nifty 50 approximate dividend yield for Black-Scholes pricing (~1.5%)
DIVIDEND_YIELD=0.015

# Minimum direction confidence (0-1) before switching from neutral to bull/bear
# Below this, both bull_put and bear_call spreads generated
# (event weeks reduce confidence by 30%)
DIRECTION_CONFIDENCE_THRESHOLD=0.35
