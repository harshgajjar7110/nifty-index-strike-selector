# ============================================================
# Nifty 50 Iron Condor Strategy — Configuration Template
# Copy to .env and adjust values as needed.
# ============================================================

# ── Strike Generation ──
STRIKE_BUFFER_POINTS=50
MIN_BUFFER_POINTS=75
WING_WIDTH_LOW_VIX=150
WING_WIDTH_MID_VIX=200
WING_WIDTH_HIGH_VIX=250
PUT_SKEW_POINTS=0
CALL_SKEW_POINTS=0
TARGET_COVERAGE=0.85

# ── Credit Spread Filters ──
MIN_DTE_TO_TRADE=7
MIN_RR_RATIO=0.15
MIN_PREMIUM_LOW_VIX_PTS=15
MIN_PREMIUM_MID_VIX_PTS=25
MIN_PREMIUM_HIGH_VIX_PTS=40
MAX_SPREADS_OUTPUT=6
MIN_OI_LIQUIDITY=5000

# ── Quantile Alphas ──
ALPHA_LOW_P10=0.10
ALPHA_LOW_P90=0.90
ALPHA_MID_P10=0.15
ALPHA_MID_P90=0.85
ALPHA_HIGH_P10=0.10
ALPHA_HIGH_P90=0.90

# ── Direction / Skew ──
PCR_BEAR_THRESHOLD=0.80
PCR_BULL_THRESHOLD=1.20
PCR_PUT_TIGHTEN_PTS=30
PCR_CALL_TIGHTEN_PTS=30
DIRECTION_CONFIDENCE_THRESHOLD=0.35
WEIGHT_ROC=0.45
WEIGHT_VIX=0.35
WEIGHT_GARCH=0.20
VOL_SKEW_FACTOR=0.03
CALL_SKEW_FACTOR=0.01

# ── Costs ──
NIFTY_LOT_SIZE=65
BROKERAGE_PER_TRADE_INR=20.0
RISK_FREE_RATE=0.065
DIVIDEND_YIELD=0.015

# ── Capital Sizing ──
IC_CAPITAL_INR=500000
IC_CAPITAL_AT_RISK_PCT=0.20
IC_TARGET_RETURN_MONTHLY_PCT=0.025
IC_TARGET_RETURN_WEEKLY_PCT=0.008
IC_EXPIRY_MODE=weekly
IC_MAX_EXTRA_BUFFER_PTS=500
IC_MIN_POP=0.75
IC_MAX_BREACH_PROB_PER_LEG=0.15

# ── Walk-Forward Backtest ──
WF_INITIAL_TRAIN_WEEKS=120
WF_RETRAIN_EVERY_WEEKS=4
WF_CALIBRATION_WEEKS=20
WF_SL_MULTIPLIER=3.0
WF_SLIPPAGE_ENTRY=1.0
WF_SLIPPAGE_EXIT=0.5

# ── Model Monitor ──
MONITOR_COVERAGE_DECAY=0.05
MONITOR_DRIFT_WINDOW_WEEKS=12
MONITOR_FEATURE_DRIFT_PVAL=0.01
