STRIKE_BUFFER_POINTS=50
WING_WIDTH_POINTS=200
TARGET_COVERAGE=0.85

# Optional: Zerodha Kite API (falls back to Yahoo Finance if unset)
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=

# Black-Scholes pricing
RISK_FREE_RATE=0.065
# Nifty 50 approximate dividend yield for Black-Scholes pricing (~1.5%)
DIVIDEND_YIELD=0.015

# Credit spread filters
MIN_RR_RATIO=0.15
DIRECTION_CONFIDENCE_THRESHOLD=0.6

# Minimum total OI (call+put) for a strike to pass liquidity filter (0 = disabled)
MIN_OI_LIQUIDITY=5000
